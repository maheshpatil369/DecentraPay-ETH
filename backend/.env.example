# ── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin123:admin123@cluster0.hqxw6ka.mongodb.net/decentrapay

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS_HERE_ABCDEF1234567890
JWT_EXPIRES_IN=7d

# ── Bcrypt ───────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Ethereum / Ganache ───────────────────────────────────────────────
# Ganache Desktop default: http://127.0.0.1:7545
# Ganache CLI default:     http://127.0.0.1:8545
GANACHE_RPC_URL=http://127.0.0.1:7545
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS_HERE

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
